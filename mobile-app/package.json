{
  "name": "medical-appointment-mobile",
  "version": "1.0.0",
  "description": "React Native mobile app for Medical Appointment System",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build-android": "cd android && ./gradlew assembleRelease",
    "build-ios": "cd ios && xcodebuild -workspace MedicalAppointmentMobile.xcworkspace -scheme MedicalAppointmentMobile -configuration Release",
    "test": "jest",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native-stack": "^6.9.0",
    "react-native-screens": "^3.25.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-gesture-handler": "^2.14.0",
    "websocket": "^1.0.34",
    "axios": "^1.6.0",
    "@react-native-firebase/app": "^18.0.0",
    "@react-native-firebase/messaging": "^18.0.0",
    "@react-native-firebase/database": "^18.0.0",
    "@react-native-firebase/analytics": "^18.0.0",
    "zustand": "^4.4.0",
    "dayjs": "^1.11.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-picker-select": "^8.1.0",
    "react-native-simple-toast": "^1.1.3",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "typescript": "^5.2.0",
    "@types/react-native": "^0.72.0",
    "prettier": "^3.0.0"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  }
}
